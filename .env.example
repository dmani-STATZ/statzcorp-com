# ─────────────────────────────────────────────────────────────────────────────
# STATZ Corporation — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is NEVER committed to source control.
# On Azure App Service, set these as Application Settings in the portal.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string-at-least-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=www.statzcorp.com,statzcorp.com

# Which settings module to load
# local  → statzcorp.settings.local
# production → statzcorp.settings.production
DJANGO_SETTINGS_MODULE=statzcorp.settings.local

# ── Database (current: SQLite) ────────────────────────────────────────────────
# SQLite is the active database. Defaults in statzcorp/settings/base.py
# point at BASE_DIR/db.sqlite3 if these are left unset.
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# ── Future: Microsoft SQL Server (MSSQL) — not active yet ─────────────────────
# When ready to migrate, install mssql-django + pyodbc (see requirements.txt),
# update settings OPTIONS for the ODBC driver / encryption, then set e.g.:
# DB_ENGINE=mssql
# DB_NAME=statzcorp
# DB_USER=statzcorp_admin
# DB_PASSWORD=your-db-password-here
# DB_HOST=your-server.database.windows.net
# DB_PORT=1433

# ── Email / SMTP ──────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@statzcorp.com
EMAIL_HOST_PASSWORD=your-smtp-password-here
DEFAULT_FROM_EMAIL=STATZ Corporation <noreply@statzcorp.com>
# Comma-separated fallback if no active ContactRecipient rows in admin.
CONTACT_EMAIL_TO=info@statzcorp.com

# ── Azure Blob Storage (Azure Government / GCCH) — video & media uploads ──────
# Leave blank for local development (falls back to local filesystem storage).
# In production, set via Azure App Service → Configuration → Application settings.
# Connection string already encodes the GCCH endpoint (core.usgovcloudapi.net).
# Never commit the real connection string. Container public access: blob-level
# anonymous read (not container listing) is intentional for marketing videos.
AZURE_CONNECTION_STRING=
AZURE_CONTAINER=media

# ── Supplier Portal → STATZWeb API (Phase 1b) ─────────────────────────────────
# Server-to-server only — statzcorp-com is the caller, STATZWeb is the API host.
# Contract: docs/supplier-portal-api-contract.md
# SUPPLIER_PORTAL_API_KEY and SUPPLIER_PORTAL_HMAC_SECRET must be the exact same
# values configured in STATZWeb's own environment — generate each with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Never commit real values. Neither value is ever sent to a supplier's browser.
SUPPLIER_PORTAL_API_BASE_URL=https://your-statzweb-host/api/supplier-portal/v1/
SUPPLIER_PORTAL_API_KEY=replace-me-must-match-statzweb
SUPPLIER_PORTAL_HMAC_SECRET=replace-me-must-match-statzweb
